# ──────────────────────────────────────────────────────────────────
# BharatAI — Environment Variables
# Copy this file to .env.local and fill in your API keys
# ──────────────────────────────────────────────────────────────────

# ── LLM Providers (at least one required) ─────────────────────────

# Anthropic Claude (recommended for BharatAI)
ANTHROPIC_API_KEY=

# Groq — ultra-fast inference (free tier available!)
# Get key: https://console.groq.com
GROQ_API_KEY=

# Groq Whisper — ultra-fast voice input in Hindi + 12 Indian languages
ASR_GROQ_API_KEY=   # Same key as GROQ_API_KEY

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Grok (xAI)
GROK_API_KEY=

# Qwen / DashScope (Alibaba)
QWEN_API_KEY=

# ── Default Model ──────────────────────────────────────────────────
# Format: providerId:modelId
# Examples:
#   anthropic:claude-sonnet-4-20250514
#   groq:llama-3.3-70b-versatile        ← Free & fast!
#   groq:meta-llama/llama-4-maverick-17b-128e-instruct
#   google:gemini-2.0-flash-exp
DEFAULT_MODEL=   # e.g. groq:llama-3.3-70b-versatile  or  anthropic:claude-sonnet-4-20250514

# ── Text-to-Speech (optional) ─────────────────────────────────────
TTS_OPENAI_API_KEY=
TTS_AZURE_API_KEY=
TTS_ELEVENLABS_API_KEY=

# ── Web Search (optional) ─────────────────────────────────────────
TAVILY_API_KEY=

# ── PDF Parsing (optional) ────────────────────────────────────────
PDF_MINERU_BASE_URL=
PDF_MINERU_API_KEY=

# ── Image Generation (optional) ───────────────────────────────────
IMAGE_SEEDREAM_API_KEY=
IMAGE_GROK_API_KEY=

# ── Access Code (optional, for hosted mode) ───────────────────────
# ACCESS_CODE=your-secret-code
